{
  "manifest_version": 3,
  "name": "ChatGPT User Markdown and LaTeX Renderer",
  "version": "0.1.0",
  "description": "Renders Markdown and common LaTeX syntax in user messages on ChatGPT web.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
